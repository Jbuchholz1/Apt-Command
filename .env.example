# === Server (.env in server/) ===
PORT=3001
BULLHORN_MCP_URL=https://your-mcp-server.up.railway.app/mcp
BULLHORN_MCP_API_KEY=your-mcp-api-key
# MCP circuit breaker tuning (lib/mcpBreaker.js) — optional; defaults shown.
# Trips after this many consecutive MCP failures, then stays open for OPEN_MS.
MCP_BREAKER_FAILURES=5
MCP_BREAKER_OPEN_MS=10000
NODE_ENV=development

# Sandbox / staging — when 'true', blocks all Bullhorn writes (update_entity,
# add_note, create_entity) at the MCP chokepoint in lib/bullhorn.js. Local
# Supabase writes (overrides, notes, goals, etc.) still work. Set to 'true'
# on the sandbox Railway service; leave unset/false in production.
READ_ONLY_MODE=false

# Background Bullhorn → Org Flow sync (every 30 min). Always on in production
# (NODE_ENV=production). In sandbox/dev, leave unset or 'false' so local runs
# don't hammer the MCP server.
ENABLE_SYNC_CRON=false

# Microsoft Entra ID (Azure AD) — required for SSO auth
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id

# Microsoft Graph — server-side app-only auth used by the nightly SharePoint
# export cron (lib/scheduledExport.js). Requires the Azure app registration
# above to have a client secret AND application-level Sites.ReadWrite.All
# (admin-consented).
AZURE_CLIENT_SECRET=your-azure-client-secret
# Target document library. Set ONE of these:
#   SHAREPOINT_DRIVE_ID  — preferred. Targets any library on any site. Get it
#                          via Graph Explorer:
#                          GET /sites/{tenant}.sharepoint.com:/sites/{site}:/drives
#                          then copy the `id` of the library you want.
#   SHAREPOINT_SITE_ID   — fallback. Uploads to the site's default ("Documents")
#                          library only.
SHAREPOINT_DRIVE_ID=your-sharepoint-drive-id
SHAREPOINT_SITE_ID=
SHAREPOINT_FOLDER_PATH=Daily Backups
# Set to 'true' to opt the export cron in locally; production runs always.
ENABLE_EXPORT_CRON=false

# Frontend URL — for CORS (set to Railway URL in production)
FRONTEND_URL=http://localhost:5173

# Supabase (server — service role key for overrides/notes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Bootstrap admin list — comma-separated emails that resolve to 'admin' even
# if their Supabase user_profiles row is missing or the DB is unreachable.
# Required: if unset, no users are bootstrap admins and Supabase user_profiles
# becomes the only path to the admin role.
BOOTSTRAP_ADMIN_EMAILS=admin1@example.com,admin2@example.com

# External (non-SSO) auth — secret used to sign/verify the email/password JWTs
# issued by /api/auth/external/login (middleware/auth.js). REQUIRED if any
# external/vendor users log in: the server throws "EXTERNAL_JWT_SECRET not
# configured" at login time if this is unset. Use a long random string.
EXTERNAL_JWT_SECRET=your-long-random-secret

# Content-Security-Policy mode:
#   off          — header not sent
#   report-only  (default) — Content-Security-Policy-Report-Only header sent;
#                  violations POST to /api/csp-report but nothing is blocked.
#   enforce      — Content-Security-Policy header sent; violations blocked.
# Recommended path: leave default (report-only) → observe logs 5–7 days → enforce.
CSP_MODE=report-only

# Optional — Microsoft Teams incoming webhook for support-ticket notifications
# (routes/support.js). Leave unset to disable Teams notifications.
TEAMS_WEBHOOK_URL=

# === Client (.env in client/) ===
# VITE_API_BASE_URL=http://localhost:3001
# VITE_AZURE_TENANT_ID=your-azure-tenant-id
# VITE_AZURE_CLIENT_ID=your-azure-client-id
# VITE_DEV_BYPASS_AUTH=true             # local dev only — skip SSO
# VITE_ENV=sandbox                      # set to 'sandbox' on the sandbox Railway frontend
                                        # to render the orange "SANDBOX" banner. Leave unset in prod.
